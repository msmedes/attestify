{
  "name": "attestify",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "import:corpus": "tsx scripts/import-gutenberg-corpus.ts",
    "build": "vite build",
    "preview": "npm run build && npm run start:preview",
    "start:preview": "PORT=3010 node .output/server/index.mjs",
    "verify:preview": "npm run build && node scripts/verify-local-preview.mjs",
    "test": "vitest run --config vitest.config.ts",
    "evals": "vitest run --config vitest.evals.config.ts --reporter=vitest-evals/reporter",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "db:generate": "drizzle-kit generate",
    "populate:embeddings": "tsx scripts/populate-embeddings.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/ai": "^0.19.1",
    "@tanstack/ai-openai": "^0.9.3",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "vectra": "^0.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "vitest-evals": "^0.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
